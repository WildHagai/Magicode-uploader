<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  IgnorableNamespaces="uap uap10 rescap com desktop4 desktop5">

  <Identity
    Name="MagicodeUploader"
    Publisher="CN=MagicodeUploader"
    Version="1.1.0.0"
    ProcessorArchitecture="neutral" />

  <Properties>
    <DisplayName>Magicode Uploader</DisplayName>
    <PublisherDisplayName>Magicode</PublisherDisplayName>
    <Logo>Assets\logo.png</Logo>
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="unvirtualizedResources" />
  </Capabilities>

  <Applications>
    <Application Id="MagicodeUploader"
      Executable="MagicodeUploader.exe"
      uap10:TrustLevel="mediumIL"
      uap10:RuntimeBehavior="win32App">
      <uap:VisualElements
        AppListEntry="none"
        DisplayName="Magicode Uploader"
        Description="Upload files to send.magicode.me"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />

      <Extensions>
        <!-- Register COM server for the context menu handler -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Magicode Upload Handler">
              <com:Class Id="7B3F2E41-1D5A-4F6E-9C8B-2A3D4E5F6071" Path="src\win11\build\MagicodeNative.dll" ThreadingModel="Both" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

        <!-- Register context menu for all file types -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="*">
              <desktop5:Verb Id="MagicodeUpload" Clsid="7B3F2E41-1D5A-4F6E-9C8B-2A3D4E5F6071" />
            </desktop5:ItemType>
            <desktop5:ItemType Type="Directory">
              <desktop5:Verb Id="MagicodeUploadDir" Clsid="7B3F2E41-1D5A-4F6E-9C8B-2A3D4E5F6071" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
